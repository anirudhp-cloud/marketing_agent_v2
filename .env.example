# OpenAI Configuration (Standard OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Azure OpenAI Configuration (Alternative to Standard OpenAI)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-02-15-preview

# FLUX-1.1-pro Configuration (Azure AI Foundry)
FLUX_API_ENDPOINT=https://your-endpoint.services.ai.azure.com/openai/deployments/FLUX-1.1-pro/images/generations?api-version=2025-04-01-preview
FLUX_API_KEY=your_flux_api_key_here
FLUX_MODEL=FLUX-1.1-pro

# Sora Video Generation Configuration
SORA_API_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com
SORA_API_KEY=your_sora_api_key_here
SORA_DEPLOYMENT_NAME=sora-2

# Store Configuration
STORE_NAME=Retail Store
STORE_TYPE=general
STORE_LOCATION=
HAS_ONLINE_STORE=false
WEBSITE_URL=

# Social Media API Configuration
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Email Configuration
SENDGRID_API_KEY=

# Database
DATABASE_URL=sqlite:///retail_marketing.db

# Application Settings
DEBUG=true
LOG_LEVEL=INFO
